# Required application secrets and database connection
DATABASE_URL="file:./dev.db"
JWT_SECRET="replace-with-a-long-random-secret"

# Core runtime configuration
NODE_ENV="production"
PORT=4000
JWT_EXPIRES_IN="1d"
JWT_REMEMBER_ME_EXPIRES_IN="7d"

# Frontend and CORS configuration
# Use CORS_ORIGINS for an explicit comma-separated allowlist.
# If CORS_ORIGINS is blank, the backend falls back to FRONTEND_ADMIN_URL and
# FRONTEND_FACILITY_URL when they are provided.
CORS_ORIGINS="https://admin.example.com,https://facility.example.com"
FRONTEND_ADMIN_URL="https://admin.example.com"
FRONTEND_FACILITY_URL="https://facility.example.com"

# SMTP fallback configuration
# These are optional because the application can also load SMTP settings from
# the database. If you set any SMTP_* variable, provide SMTP_HOST, SMTP_PORT,
# and SMTP_DEFAULT_SENDER_EMAIL together.
SMTP_HOST=""
SMTP_PORT=587
SMTP_USERNAME=""
SMTP_PASSWORD=""
SMTP_ENCRYPTION="TLS"
SMTP_SENDER_NAME="JP Amota Medical Waste"
SMTP_REPLY_EMAIL="support@example.com"
SMTP_DEFAULT_SENDER_EMAIL="no-reply@example.com"

# Maps integration
# The current backend route planner builds Google Maps links without a server
# key, but this placeholder is documented for production environment parity.
GOOGLE_MAPS_API_KEY=""

# Cloudinary placeholders
# The current backend source does not upload through Cloudinary at startup, but
# these keys are documented here for production deployment completeness.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_FOLDER="porta-server"
